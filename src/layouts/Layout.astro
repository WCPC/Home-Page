---
interface Props {
    title?: string;
    description?: string;
}

const { title = "WCPC", description = "和歌山大学競技プログラミングサークル" } =
    Astro.props;
---

<!doctype html>
<html lang="ja">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="description" content={description} />
        <title>{title} | WCPC</title>

        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Roboto:wght@400;500;700&display=swap"
            rel="stylesheet"
        />
    </head>
    <body
        class="m-0 p-0 bg-white text-gray-900 font-noto min-h-screen flex flex-col"
    >
        <slot />
    </body>
</html>
