---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("activities")).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout title="ホーム" description="和歌山大学競技プログラミングサークル WCPC">
    <Header />

    <!-- Hero -->
    <section class="w-full text-center py-16 px-5 border-b border-gray-100">
        <h1 class="font-roboto font-bold text-6xl md:text-8xl mb-3">WCPC</h1>
        <p
            class="font-roboto font-bold text-xl md:text-2xl text-orange-500 mb-10"
        >
            和歌山大学 競技プログラミングサークル
        </p>
        <img
            src="/images/wcpc-hero.webp"
            alt="WCPC's Hero"
            class="max-w-xl w-full mx-auto rounded-2xl object-cover shadow-sm"
            loading="eager"
        />
    </section>

    <div id="about" class="my-5"></div>

    <main class="flex-1 max-w-4xl mx-auto px-5 py-16 w-full">
        <!-- About -->
        <section class="mb-16">
            <h2 class="font-roboto font-bold text-4xl mb-6">私たちについて</h2>
            <p class="text-base md:text-lg leading-relaxed text-gray-700">
                私たちはなんっちゃらかんちゃらをなんとかすることでICPCの優勝を目指しています。
            </p>
            <p class="text-base md:text-lg leading-relaxed text-gray-700">
                あとAtCoderの副社長は和歌山大学出身です。
            </p>
        </section>

        <!-- contact -->
        <section class="mb-16">
            <h2 class="font-roboto font-bold text-4xl mb-6">参加するには</h2>
            <p class="text-base md:text-lg leading-relaxed text-gray-700">
                右上の問い合わせフォームからお問い合わせください。
            </p>
            <p class="text-base md:text-lg leading-relaxed text-gray-700">
                Discordの新歓サーバのURLや簡単な質問をメールでお送りいたします。
            </p>
        </section>

        <!-- 活動記事 -->
        <section>
            <h2 class="font-roboto font-bold text-4xl mb-6">活動記事</h2>
            {
                posts.length === 0 ? (
                    <p class="text-gray-400 py-10 text-center">
                        まだ記事がありません。
                    </p>
                ) : (
                    <ul class="space-y-4">
                        {posts.map((post) => (
                            <li>
                                <a
                                    href={`/activities/${post.id.replace(".mdx", "")}`}
                                    class="flex flex-col sm:flex-row sm:items-center gap-3 p-5 rounded-2xl bg-orange-50 hover:bg-orange-100 transition-colors duration-200 no-underline group"
                                >
                                    <span class="text-sm text-gray-400 shrink-0 sm:w-28">
                                        {post.data.date.toLocaleDateString(
                                            "ja-JP",
                                        )}
                                    </span>
                                    <div class="flex flex-wrap gap-1.5 shrink-0">
                                        {post.data.tags.map((tag) => (
                                            <span class="text-xs bg-orange-200 text-orange-700 px-2 py-0.5 rounded-full">
                                                {tag}
                                            </span>
                                        ))}
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <p class="font-roboto font-bold text-gray-900 group-hover:text-orange-500 transition-colors duration-200">
                                            {post.data.title}
                                        </p>
                                        {post.data.description && (
                                            <p class="text-sm text-gray-500 mt-0.5">
                                                {post.data.description}
                                            </p>
                                        )}
                                    </div>
                                    <span class="text-orange-300 group-hover:text-orange-500 transition-colors duration-200 hidden sm:block shrink-0">
                                        →
                                    </span>
                                </a>
                            </li>
                        ))}
                    </ul>
                )
            }
        </section>
    </main>

    <Footer />
</Layout>
